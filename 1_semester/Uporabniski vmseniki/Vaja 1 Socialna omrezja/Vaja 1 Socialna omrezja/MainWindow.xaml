<Window x:Class="Vaja_1_Socialna_omrezja.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Vaja_1_Socialna_omrezja"
        mc:Ignorable="d"
        Title="Socialno Omrežje" Height="450" Width="800"
        MinWidth="600" MinHeight="400">

    <Window.Resources>
        <SolidColorBrush x:Key="BackgroundColor" Color="#FF99C0FB"/>
    </Window.Resources>

    <Grid Background="{StaticResource BackgroundColor}">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>

        <Menu Grid.Row="0" Background="LightBlue">
            <MenuItem Header="Datoteka">
                <MenuItem Header="Izhod" Command="{Binding IzhodCommand}"/>
            </MenuItem>

            <MenuItem Header="Objave">
                <MenuItem Header="Dodaj statično" Command="{Binding DodajStaticnoCommand}"/>
                <MenuItem Header="Uredi statično" Command="{Binding UrediStaticnoCommand}"  IsEnabled="{Binding JeIzbranaObjava}"/>
                <MenuItem Header="Dodaj" Command="{Binding DodajCommand}"/>
                <MenuItem Header="Uredi" Command="{Binding UrediCommand}" IsEnabled="{Binding JeIzbranaObjava}"/>
                <MenuItem Header="Odstrani" Command="{Binding OdstraniCommand}"  IsEnabled="{Binding JeIzbranaObjava}"/>
            </MenuItem>
        </Menu>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" MinWidth="150"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="10">
                <TextBlock Text="{Binding ImePriimek}" HorizontalAlignment="Center"  FontSize="25" TextWrapping="Wrap" Margin="5" FontWeight="Bold"/>

                <Image Source="/Images/profile.jpg" Height="150" HorizontalAlignment="Center" Stretch="Uniform"/>

                <TextBlock Text="{Binding Biografija}"  FontSize="16" TextWrapping="Wrap" Margin="10" TextAlignment="Center"/>
            </StackPanel>

            <TabControl Grid.Column="1" Margin="5">
                <TabItem Header="Zid">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <ListView x:Name="seznamObjav" Grid.Row="0" Margin="5" ItemsSource="{Binding Objave}" SelectedItem="{Binding IzbranaObjava}">

                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                </Style>
                            </ListView.ItemContainerStyle>

                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="LightGray" BorderThickness="1" Margin="5" Padding="5">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <Image Source="{Binding SlikaObjava}" Margin="5" Stretch="Uniform" Height="80"/>

                                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                                <TextBlock Text="{Binding Naslov}" FontWeight="Bold" FontSize="14"/>
                                                <TextBlock Text="{Binding Vsebina}" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding Datum, StringFormat='dd.MM.yyyy HH:mm'}" FontStyle="Italic" Foreground="Gray"/>
                                                <TextBlock Text="{Binding Avtor}" />

                                                <TextBlock Foreground="Red">
                                                    <Run Text="❤"/> 
                                                    <Run Text="{Binding Vsec}"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </Grid>

                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="White"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding JeIzbrana}" Value="True">
                                                        <Setter Property="Background" Value="LightBlue"/>
                                                        <Setter Property="BorderBrush" Value="Blue"/>
                                                        <Setter Property="BorderThickness" Value="2"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Vsec}" Value="0">
                                                        <Setter Property="Background" Value="LightYellow"/>
                                                        <Setter Property="BorderBrush" Value="Orange"/>
                                                        <Setter Property="BorderThickness" Value="2"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <Border Grid.Row="1" BorderThickness="1" BorderBrush="Gray" Padding="5"  Background="#FFF1F1F1" HorizontalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" >
                                <Button x:Name="gumbVsec" Height="40" Width="80" Margin="10"   Command="{Binding VsecCommand}">
                                    <StackPanel>
                                        <Image Source="/Images/likeB.png" Width="20" Height="20"/>
                                        <TextBlock Text="Like" FontSize="10" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="gumbComent" Height="40" Width="80" Margin="10" Command="{Binding CommentCommand}">
                                    <StackPanel>
                                        <Image Source="/Images/comment.png" Width="20" Height="20"/>
                                        <TextBlock Text="Comment" FontSize="10" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="O meni">
                    <ScrollViewer>
                        <StackPanel Margin="15">
                            <TextBlock Text="O meni" FontWeight="Bold" FontSize="16"/>

                            <Image Source="/Images/profile.jpg" Width="200" Height="200" HorizontalAlignment="Left" Margin="10" Stretch="Uniform"/>

                            <TextBlock Text="Ime in priimek:"/>
                            <TextBox Text="{Binding ImePriimek, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Text="Opis:" Margin="0,10,0,0"/>
                            <TextBox Text="{Binding Biografija, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"    TextWrapping="Wrap" Height="60"/>

                            <WrapPanel Margin="0,10,0,0">
                                <Image Source="/Images/email.png" Width="20" Height="20" />
                                <TextBlock Text="janez.novak@email.com" VerticalAlignment="Center" Margin="5,0,0,0"/>
                            </WrapPanel>
                            <WrapPanel Margin="0,5,0,0">
                                <Image Source="/Images/phone.png" Width="20" Height="20" />
                                <TextBlock Text="+386 41 123 456" VerticalAlignment="Center" Margin="5,0,0,0"/>
                            </WrapPanel>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>

        <StatusBar Grid.Row="2" Background="LightGray">
            <TextBlock Text="{Binding ImePriimek, StringFormat='Prijavljen kot: {0}'}"/>
        </StatusBar>
    </Grid>
</Window>