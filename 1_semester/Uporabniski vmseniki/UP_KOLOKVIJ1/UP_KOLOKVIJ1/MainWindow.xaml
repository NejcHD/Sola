<Window x:Class="UP_KOLOKVIJ1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Moja Aplikacija" Height="450" Width="800"
        MinWidth="600" MinHeight="400"
        Closing="Window_Closing">
    <!-- DODAJTE: Dogodek za zapiranje -->

    <TabControl>
        <!-- Zavihek 1: Grid -->
        <TabItem Header="Grid">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Navigation Bar -->
                <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" 
                            Orientation="Horizontal" Background="LightBlue" Height="40">
                    <Menu>
                        <MenuItem Header="Domov"/>
                        <MenuItem Header="O nas"/>
                        <MenuItem Header="Kontakt"/>
                        <MenuItem Header="Nastavitve"/>
                    </Menu>
                </StackPanel>

                <!-- Glavna vsebina Z DOGODKI -->
                <Button Grid.Column="0" Grid.Row="1" Content="Gumb 1" Margin="10"
                        Click="Gumb1_Click"/>
                <!-- DODAJTE: Click dogodek -->

                <TextBox Grid.Column="0" Grid.Row="2" Text="Vnos 1" Margin="10"
                         TextChanged="TextBox_TextChanged"/>
                <!-- DODAJTE: TextChanged dogodek -->

                <TextBox Grid.Column="1" Grid.Row="1" Text="Vnos 2" Margin="10"
                         TextChanged="TextBox_TextChanged"/>
                <!-- DODAJTE: TextChanged dogodek -->

                <Button Grid.Column="1" Grid.Row="2" Content="Gumb 2" Margin="10"
                        Click="Gumb2_Click"/>
                <!-- DODAJTE: Click dogodek -->

                <TextBlock Grid.Column="2" Grid.Row="1" Text="Tekst 1" Margin="10"/>

                <Button Grid.Column="2" Grid.Row="2" Content="Gumb 3" Margin="10"
                        Click="Gumb3_Click"/>
                <!-- DODAJTE: Click dogodek -->

                <!-- Status Bar -->
                <StatusBar Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Background="LightGray">
                    <StatusBarItem>
                        <TextBlock x:Name="StatusText" Text="Pripravljen" FontStyle="Italic"/>
                    </StatusBarItem>
                    <StatusBarItem HorizontalAlignment="Right">
                        <TextBlock Text="Vse sistemske komponente delujejo normalno"/>
                    </StatusBarItem>
                </StatusBar>
            </Grid>
        </TabItem>

        <!-- Ostali zavihki ostanejo enaki -->
        <TabItem Header="StackPanel">
            <StackPanel Orientation="Vertical">
                <TextBlock Background="red" Height="30">HALO 1</TextBlock>
                <TextBlock Background="Green" Height="30">HALO 2</TextBlock>
                <TextBlock Background="Blue" Height="30">HALO 3</TextBlock>
                <TextBlock Background="Yellow" Height="30">HALO 4</TextBlock>
            </StackPanel>
        </TabItem>

        <TabItem Header="DockPanel">
            <DockPanel LastChildFill="True">
                <TextBlock DockPanel.Dock="Top" Background="red" Height="30">ZGORAJ</TextBlock>
                <TextBlock DockPanel.Dock="Bottom" Background="Green" Height="30">SPODAJ</TextBlock>
                <TextBlock DockPanel.Dock="Left" Background="Blue" Width="100">LEVO</TextBlock>
                <TextBlock DockPanel.Dock="Right" Background="Yellow" Width="100">DESNO</TextBlock>
                <TextBlock Background="Orange">SREDINA</TextBlock>
            </DockPanel>
        </TabItem>

        <TabItem Header="WrapPanel">
            <WrapPanel>
                <TextBlock Background="red" Width="100" Height="30" Margin="5">HALO 1</TextBlock>
                <TextBlock Background="Green" Width="100" Height="30" Margin="5">HALO 2</TextBlock>
                <TextBlock Background="Blue" Width="100" Height="30" Margin="5">HALO 3</TextBlock>
                <TextBlock Background="Yellow" Width="100" Height="30" Margin="5">HALO 4</TextBlock>
            </WrapPanel>
        </TabItem>

        <TabItem Header="Slike">
            <WrapPanel>
                <Image Source="/Images/comment.png" Width="200" Height="100" Margin="5"/>
                <Image Source="/Images/phone.png" Width="200" Height="100" Margin="5"/>
                <Image Source="/Images/slika2.jpg" Width="200" Height="100" Margin="5"/>
                <Image Source="/Images/likeB.png" Width="200" Height="100" Margin="5"/>
            </WrapPanel>
        </TabItem>
    </TabControl>
</Window>