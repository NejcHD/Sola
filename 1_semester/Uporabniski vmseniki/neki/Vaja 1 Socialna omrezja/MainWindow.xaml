<Window x:Class="Vaja_1_Socialna_omrezja.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Socialno Omrežje" Height="550" Width="850">

    <Window.Resources>
        <SolidColorBrush x:Key="BarvaOzadja" Color="#FF99C0FB"/>
    </Window.Resources>

    <Grid Background="{StaticResource BarvaOzadja}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Menu Grid.Row="0" Background="LightBlue" Padding="5">
            <MenuItem Header="Datoteka">
                <MenuItem Header="Izhod" Command="{Binding IzhodCommand}"/>
            </MenuItem>
            <MenuItem Header="Objave">
                <MenuItem Header="Dodaj novo..." Command="{Binding OdpriDodajCommand}"/>
                <MenuItem Header="Uredi izbrano..." Command="{Binding OdpriUrediCommand}"/>
                <Separator/>
                <MenuItem Header="Prekliči izbiro" Command="{Binding PrekliciIzbiroCommand}"/>
                <MenuItem Header="Odstrani" Command="{Binding OdstraniCommand}"/>
            </MenuItem>
        </Menu>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="10" Background="#80FFFFFF">
                <TextBlock Text="{Binding ImePriimek}" HorizontalAlignment="Center" FontSize="20" FontWeight="Bold" Margin="5" TextWrapping="Wrap"/>
                <Image Source="/Images/profile.jpg" Height="140" Margin="5"/>
                <TextBlock Text="{Binding Biografija}" FontSize="14" Margin="10" TextAlignment="Center" TextWrapping="Wrap"/>
            </StackPanel>

            <TabControl Grid.Column="1" Margin="5">
                <TabItem Header="Zid">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <ListView ItemsSource="{Binding Objave}" SelectedItem="{Binding IzbranaObjava}" HorizontalContentAlignment="Stretch">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="Gray" BorderThickness="1" Margin="2" Padding="10" Background="White">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Image Grid.Column="0" Source="/Images/profile.jpg" Width="50" Height="50" Margin="0,0,10,0" VerticalAlignment="Top"/>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding Naslov}" FontWeight="Bold" FontSize="16"/>
                                                <TextBlock Text="{Binding Vsebina}" TextWrapping="Wrap" Margin="0,5"/>
                                                <TextBlock Text="{Binding Vsec, StringFormat='❤️ {0}'}" Foreground="Red" FontWeight="Bold"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="5">
                            <Button Content="Všečkaj" Width="90" Height="35" Margin="5" Command="{Binding VsecCommand}"/>
                            <Button Content="Uredi" Width="90" Height="35" Margin="5" Command="{Binding OdpriUrediCommand}"/>
                            <Button Content="Prekliči" Width="90" Height="35" Margin="5" Command="{Binding PrekliciIzbiroCommand}"/>
                        </StackPanel>
                    </Grid>
                </TabItem>

                <TabItem Header="O meni">
                    <StackPanel Margin="20">
                        <TextBlock Text="Uredi Ime:" FontWeight="Bold"/>
                        <TextBox Text="{Binding ImePriimek, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,15"/>
                        <TextBlock Text="Uredi Biografijo:" FontWeight="Bold"/>
                        <TextBox Text="{Binding Biografija, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" Height="80"/>
                    </StackPanel>
                </TabItem>
            </TabControl>
        </Grid>

        <Border Grid.Row="2" Background="#007ACC" Padding="10">
            <TextBlock Text="{Binding DostopniUkazi}" Foreground="White" HorizontalAlignment="Center" />
        </Border>

        <StatusBar Grid.Row="3" Background="LightGray">
            <TextBlock Text="{Binding StatusGlasa}"/>
        </StatusBar>
    </Grid>
</Window>