@model List<Naloga1_Dinamicna.Models.Rezervacija>

<div class="container mt-4">
    <h2 class="text-center mb-4">Seznam rezervacij</h2>

    <div class="table-responsive">
        <table class="table table-hover table-striped custom-table-style">
            <thead class="thead-dark">
                <tr>
                    <th>Id</th>
                    <th>Št. rezervacije</th>
                    <th>Potnik</th>
                    <th>Št. leta</th>
                    <th>Datum rezervacije</th>
                    <th>Razred</th>
                    <th>Skupna cena</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var rezervacija in Model)
                {
                    <tr>
                        <td>@rezervacija.Id</td>
                        <td><strong>@rezervacija.StevilkaRezervacije</strong></td>
                        <td>@rezervacija.PotnikIme</td>
                        <td>@rezervacija.StevilkaLeta</td>
                        <td>@rezervacija.DatumRezervacije.ToString("dd. MM. yyyy")</td>
                        <td>@rezervacija.RazredSedeza</td>
                        <td>@rezervacija.SkupnasCena.ToString("N2") €</td>
                        <td>
                            @* Opcijsko: dodajanje barvne značke glede na status *@
                            <span class="badge @(rezervacija.Status == "Potrjeno" ? "bg-success" : "bg-warning text-dark")">
                                @rezervacija.Status
                            </span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
<hr />

<div id="moj-harmonika">
    <h3>Kaj je status "Potrjeno"?</h3>
    <div>
        <p>To pomeni, da je vaš let uradno rezerviran in sedež v letalu zagotovljen.</p>
    </div>
    <h3>Kako odpovem rezervacijo?</h3>
    <div>
        <p>Rezervacijo lahko odpoveste v nastavitvah vašega profila ali nas pokličete.</p>
    </div>
</div>