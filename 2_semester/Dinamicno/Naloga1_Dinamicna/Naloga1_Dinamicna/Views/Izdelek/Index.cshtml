@model Naloga1_Dinamicna.Models.IzdelekViewModel

@{
    ViewData["Title"] = "Vnos izdelka";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <h2 class="text-center mb-4">Dodajanje novega izdelka</h2>

            <form asp-action="Index" method="post">
                @Html.AntiForgeryToken()

                @Html.EditorForModel()

                <div class="mt-4">
                    <button type="submit" class="btn btn-success btn-lg w-100">Potrdi izdelek</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}