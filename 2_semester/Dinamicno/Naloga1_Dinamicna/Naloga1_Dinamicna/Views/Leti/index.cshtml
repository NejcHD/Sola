@model List<Naloga1_Dinamicna.Models.Let>

<div class="container mt-4">
    <h2 class="text-center mb-4">Seznam razpoložljivih letov</h2>

    <div class="table-responsive">
        <table class="table table-hover table-striped custom-table-style">
            <thead class="thead-dark">
                <tr>
                    <th>Id</th>
                    <th>Številka leta</th>
                    <th>Izhodišče</th>
                    <th>Cilj</th>
                    <th>Datum odhoda</th>
                    <th>Datum prihoda</th>
                    <th>Cena (Econ)</th>
                    <th>Cena (Bus)</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var let in Model)
                {
                    <tr>
                        <td>@let.Id</td>
                        <td><strong>@let.StevilkaLeta</strong></td>
                        <td>@let.IzhodisceLokacija</td>
                        <td>@let.CiljnaLokacija</td>
                        <td>@let.DatumOdhoda.ToString("dd. MM. yyyy")</td>
                        <td>@let.DatumPrihoda.ToString("dd. MM. yyyy")</td>
                        <td>@let.CenaNajcenejsega €</td>
                        <td>@let.CenaBusiness €</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>